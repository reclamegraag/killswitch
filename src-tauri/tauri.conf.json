{
  "productName": "KillSwitch",
  "version": "0.1.0",
  "identifier": "com.killswitch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "KillSwitch",
        "width": 400,
        "height": 500,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
